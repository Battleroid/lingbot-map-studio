# Public API base visible to the browser. Use the host port that Compose publishes.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# info | debug | warning
LOG_LEVEL=info

# 1 to install flashinfer-python at image-build time (cu128/torch2.9).
# 0 (default) uses the SDPA attention fallback — simpler image, slightly slower.
USE_FLASHINFER=0
