# ─── Web frontend ──────────────────────────────────────────────────────
# Public API base visible to the browser. Use the host port that Compose
# publishes. NOTE: Next.js inlines NEXT_PUBLIC_* env vars at build time,
# so changing this requires `docker compose build web` to take effect.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# ─── Logging ───────────────────────────────────────────────────────────
# info | debug | warning
LOG_LEVEL=info

# ─── Lingbot worker ────────────────────────────────────────────────────
# 1 to install flashinfer-python at image-build time (cu128 / torch 2.9).
# 0 (default) uses the SDPA attention fallback — simpler image, slightly
# slower inference.
USE_FLASHINFER=0

# ─── Cloud execution (Phase R1+) — optional ────────────────────────────
# Only set these if you plan to dispatch jobs to rented cloud GPUs. Local
# `execution_target=local` jobs (the default) ignore everything below.

# Public URL by which a remote worker pod reaches THIS api process. For
# local dev, `localhost:8000` only works when the pod is on the same
# host. For real remote execution expose the api via a tunnel
# (Cloudflare Tunnel / Tailscale Funnel) and set this to the tunnel URL.
# CLOUD_BROKER_PUBLIC_URL=http://localhost:8000

# Shared secret signing per-job HMAC tokens issued to remote workers.
# CHANGE THIS before exposing the broker to the internet — leaked tokens
# minted under the default key let an attacker publish events as any job.
# CLOUD_BROKER_HMAC_KEY=change-me-in-production

# Studio-wide hard ceiling on per-job cloud spend in cents. Dispatcher
# refuses to launch when the estimated cost exceeds this regardless of
# any per-job override. Default is $50.
# CLOUD_COST_CAP_CENTS_DEFAULT=5000

# Per-provider API keys. Each adapter only registers itself if its key
# is set, so an empty value here means the provider stays absent from
# the ExecutionPanel dropdown.
# RUNPOD_API_KEY=
# VAST_API_KEY=
# LAMBDA_LABS_API_KEY=
# PAPERSPACE_API_KEY=

# AWS / GCP / Azure use their own SDK credential chains (env, ~/.aws/,
# instance metadata, etc.). Set the *_REGION_DEFAULT vars to override
# where instances launch by default; leave the *_ENDPOINT vars blank
# unless you're targeting LocalStack / a private endpoint / gov-cloud.
# AWS_REGION_DEFAULT=us-east-1
# AWS_ENDPOINT_URL=
# GCP_REGION_DEFAULT=us-central1
# GCP_SERVICE_ACCOUNT_JSON=
# AZURE_REGION_DEFAULT=eastus
# AZURE_SUBSCRIPTION_ID=

# ─── Artifact transport (Phase R5) — optional ──────────────────────────
# `broker` (default) routes artifact bytes through the api process. Set
# to `minio` to have remote workers upload directly to a self-hosted
# S3-compatible bucket. Bring the bucket up alongside the rest of the
# stack with `docker compose --profile cloud-storage up`.
# CLOUD_STORAGE=broker
# MINIO_ACCESS_KEY=lingbot
# MINIO_SECRET_KEY=lingbot-minio-dev
# MINIO_BUCKET=lingbot-artifacts
# MINIO_ENDPOINT_URL=http://minio:9000
